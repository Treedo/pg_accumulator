{
  "name": "prisma-accumulator",
  "version": "0.1.0",
  "description": "Prisma ORM adapter for pg_accumulator — type-safe accumulation registers in your Prisma project",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
